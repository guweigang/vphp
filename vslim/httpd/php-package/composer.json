{
  "name": "vphpext/vhttpd-php",
  "description": "VHttpd PHP bridge package (manager, PSR-7 bridge, VSlim adapter)",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "VHttpd\\": "src/"
    }
  },
  "suggest": {
    "nyholm/psr7": "PSR-17 factory support",
    "guzzlehttp/psr7": "PSR-17 factory support",
    "laminas/laminas-diactoros": "PSR-17 factory support"
  }
}
