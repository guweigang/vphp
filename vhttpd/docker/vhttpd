#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
IMAGE="${VHTTPD_DOCKER_IMAGE:-vhttpd-dev:latest}"
DATA_PORT_MAP="${VHTTPD_DOCKER_PORT_MAP:-19881:19881}"
ADMIN_PORT_MAP="${VHTTPD_DOCKER_ADMIN_PORT_MAP:-19981:19981}"

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  docker build -t "$IMAGE" -f "$ROOT/vhttpd/docker/Dockerfile" "$ROOT"
fi

exec docker run --rm \
  -p "$DATA_PORT_MAP" \
  -p "$ADMIN_PORT_MAP" \
  "$IMAGE" \
  "$@"
